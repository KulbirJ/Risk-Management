# FastAPI Configuration
DEBUG=False
LOG_LEVEL=INFO

# Database Configuration
# For local dev: use plain DATABASE_URL
DATABASE_URL=postgresql://admin:password@localhost:5432/multitenantpostgresdb
DB_ECHO=False
DB_NAME=multitenantpostgresdb

# AWS Configuration
AWS_REGION=ca-central-1
AWS_ACCOUNT_ID=031195399879

# S3 Configuration
S3_BUCKET_EVIDENCE=compliance-platform-dev-evidence
S3_BUCKET_REGION=ca-central-1

# Cognito Configuration
COGNITO_DOMAIN=compliance-platform-dev
COGNITO_USER_POOL_ID=ca-central-1_XXXXXXXX
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_CLIENT_SECRET=your-app-client-secret (if applicable)
COGNITO_REGION=ca-central-1

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your-secret-key-for-local-dev-only
JWT_EXPIRATION_HOURS=24

# Secrets Manager Configuration
# Set to True when deployed to AWS to fetch DB credentials from Secrets Manager
USE_SECRETS_MANAGER=False
SECRETS_MANAGER_REGION=ca-central-1
DB_SECRET_NAME=compliance-platform/db/credentials
DB_SECRET_ARN=arn:aws:secretsmanager:ca-central-1:031195399879:secret:compliance-platform/db/credentials

# Local Development (use localstack or real AWS)
USE_LOCALSTACK=False
LOCALSTACK_ENDPOINT_URL=http://localhost:4566

# Phase 1: AI/Intelligence (future)
BEDROCK_ENABLED=False
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_REGION=ca-central-1
OPENAI_API_KEY=

# Application Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_UPLOAD_SIZE_MB=500
EVIDENCE_RETENTION_DAYS=365
